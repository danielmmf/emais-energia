# Telegram bot
TELEGRAM_BOT_TOKEN=
# Opcional: se vazio, envia para todos os chats ativos do bot (via getUpdates)
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_NAME=Viabilidade Verde Bot
TELEGRAM_POLL_TIMEOUT=20

# Groq (IA de resposta do bot)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Deploy endpoint
DEPLOY_ENDPOINT_URL=https://emais-energia.devinhas.com.br/deploy/pull.php
DEPLOY_ENDPOINT_TOKEN=baconpedacudo

# Playwright
PLAYWRIGHT_BASE_URL=https://emais-energia.devinhas.com.br
MENTOR_NAME=Mentor QA
MENTOR_PASSWORD=baconpedacudo

# GitHub repository (owner/repo)
GITHUB_REPOSITORY=danielmmf/emais-energia

# Firebase Realtime Database
FIREBASE_DATABASE_URL=https://emais-energia-default-rtdb.firebaseio.com
